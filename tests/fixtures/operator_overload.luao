class Vector2
    public x: number
    public y: number

    new(x: number, y: number)
        self.x = x
        self.y = y
    end

    public function __add(other: Vector2): Vector2
        return new Vector2(self.x + other.x, self.y + other.y)
    end

    public function __sub(other: Vector2): Vector2
        return new Vector2(self.x - other.x, self.y - other.y)
    end

    public function __mul(scalar: number): Vector2
        return new Vector2(self.x * scalar, self.y * scalar)
    end

    public function __eq(other: Vector2): boolean
        return self.x == other.x and self.y == other.y
    end

    public function __tostring(): string
        return "(" .. self.x .. ", " .. self.y .. ")"
    end

    public function __len(): number
        return (self.x * self.x + self.y * self.y) ^ 0.5
    end

    public function dot(other: Vector2): number
        return self.x * other.x + self.y * other.y
    end
end

local a = new Vector2(1, 2)
local b = new Vector2(3, 4)
local c = a + b
print(tostring(c))
print(a:dot(b))
