interface Drawable
    function draw(x: number, y: number): void
end

interface Resizable
    function resize(factor: number): void
end

class Circle implements Drawable, Resizable
    private radius: number
    private x: number
    private y: number

    new(radius: number)
        self.radius = radius
        self.x = 0
        self.y = 0
    end

    public function draw(x: number, y: number): void
        self.x = x
        self.y = y
        print("Drawing circle at " .. x .. ", " .. y .. " with radius " .. self.radius)
    end

    public function resize(factor: number): void
        self.radius = self.radius * factor
    end
end

local c = new Circle(10)
c:draw(100, 200)
c:resize(2)
c:draw(100, 200)
